# plc-server — copy to .env or set in the shell

PLC_SERVER_PORT=3030
PLC_MILL3_HOST=192.168.0.17
PLC_MILL3_PORT=102
PLC_MILL3_RACK=0
PLC_MILL3_SLOT=2
PLC_MILL3_POLL_MS=2000
PLC_MILL3_RETRY_MS=5000

# NDT labels from PLC counts (set ENABLE_PLC_LABEL_PRINT=0 to disable)
ENABLE_PLC_LABEL_PRINT=1
PLC_MILL_NUMBER=3
WIP_BUNDLE_FOLDER=Z:\To SAP\TM\Bundle

PRINTER_HOST=192.168.0.125
PRINTER_PORT=9100
