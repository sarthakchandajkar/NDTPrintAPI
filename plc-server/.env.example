# plc-server — copy to .env (or copy .env.production to .env on the VM)

PLC_SERVER_PORT=3030
PLC_SERVER_HOST=0.0.0.0
# Dashboard origin for Socket.IO CORS (use VM LAN IP in production)
PLC_SERVER_CORS_ORIGIN=http://localhost:3000
PLC_ENABLED_MILLS=1,2,3,4

# Shared defaults (per-mill *_HOST overrides below)
PLC_POLL_MS=2000
PLC_RETRY_MS=5000
PLC_PORT=102
PLC_RACK=0
PLC_SLOT=2

# Mill-1 — PO end M40.6, MES ack M40.7
PLC_MILL1_HOST=192.168.0.13

# Mill-2 — PO end M40.6, MES ack M40.7
PLC_MILL2_HOST=192.168.0.60

# Mill-3 — PO end M20.6, MES ack M22.7
PLC_MILL3_HOST=192.168.0.17

# Mill-4 — PO end M41.6, MES ack M41.7
PLC_MILL4_HOST=192.168.0.19

# NDT labels from PLC counts (Mill-3 only by default; set ENABLE_PLC_LABEL_PRINT=0 to disable)
ENABLE_PLC_LABEL_PRINT=1
PLC_MILL_NUMBER=3
WIP_BUNDLE_FOLDER=Z:\To SAP\TM\Bundle

PRINTER_HOST=192.168.0.125
PRINTER_PORT=9100
# PRINTER_LOCAL_BIND=192.168.x.x
# NDT_LABEL_STATION_TEXT=Visual
